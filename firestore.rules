rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin: custom claim `admin` OR document admins/{uid}.
    // Bootstrap: Console → `admins` collection → doc id = your Auth UID (empty map is fine), then deploy rules.
    function isAdmin() {
      return isSignedIn() &&
        (
          request.auth.token.admin == true ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    // Keys a normal user may set on first create of their profile (subset / merge create).
    function userCreateAllowedKeys() {
      return [
        'uid',
        'email',
        'name',
        'full_name',
        'university',
        'major',
        'academic_year',
        'gpa',
        'skills',
        'internships',
        'clubs',
        'projects',
        'profile_completed',
        'createdAt',
        'targetJobId',
        'added_courses',
        'analysis_results',
        'last_analysis',
        'last_analysis_title',
        'last_analysis_at',
        'photoUrl',
        'photoUpdatedAt',
        'fcmToken',
        'fcmTokenUpdatedAt',
        'age'
      ];
    }

    // Keys a user may change on their own document (diff must be subset). No role / suspension here.
    function userSelfUpdateAllowedKeys() {
      return [
        'uid',
        'email',
        'name',
        'full_name',
        'university',
        'major',
        'academic_year',
        'gpa',
        'skills',
        'internships',
        'clubs',
        'projects',
        'profile_completed',
        'targetJobId',
        'added_courses',
        'analysis_results',
        'last_analysis',
        'last_analysis_title',
        'last_analysis_at',
        'photoUrl',
        'photoUpdatedAt',
        'fcmToken',
        'fcmTokenUpdatedAt',
        'age'
      ];
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);

      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        !('role' in request.resource.data) &&
        !('isSuspended' in request.resource.data) &&
        request.resource.data.keys().hasOnly(userCreateAllowedKeys());

      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfUpdateAllowedKeys())
        ) ||
        (
          isAdmin() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isSuspended'])
        )
      );

      // Account deletion from clients is disabled; use Admin tools / Cloud Functions if needed.
      allow delete: if isAdmin();
    }

    // Jobs: all signed-in users may read; only admins may create/update/delete.
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /insights/{insightId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /market_trends/{trendId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /admins/{adminUid} {
      allow read: if isSignedIn() && (
        request.auth.uid == adminUid ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }
  }
}
