rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin if custom claim is set OR UID exists in admins collection.
    // Bootstrap first admin: Firebase Console → Firestore → collection `admins` → document ID = your Auth UID (empty map is fine).
    // Then deploy these rules, sign out/in. Or use Cloud Function makeAdmin if another admin exists.
    function isAdmin() {
      return isSignedIn() &&
        (
          request.auth.token.admin == true ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    // Users: read own doc or any user doc if admin (analytics / streamUsers).
    // Clients cannot set or change `role` (admin is claim + admins/{uid} + makeAdmin Cloud Function only).
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId
        && !('role' in request.resource.data)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'name',
          'full_name',
          'university',
          'major',
          'academic_year',
          'gpa',
          'skills',
          'internships',
          'clubs',
          'projects',
          'profile_completed',
          'createdAt',
          'targetJobId',
          'added_courses',
          'analysis_results',
          'last_analysis',
          'last_analysis_title',
          'last_analysis_at',
          'photoUrl',
          'fcmToken',
          'fcmTokenUpdatedAt',
          'age'
        ]);
      allow update: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'full_name',
          'university',
          'major',
          'academic_year',
          'gpa',
          'skills',
          'internships',
          'clubs',
          'projects',
          'profile_completed',
          'targetJobId',
          'added_courses',
          'analysis_results',
          'last_analysis',
          'last_analysis_title',
          'last_analysis_at',
          'photoUrl',
          'fcmToken',
          'fcmTokenUpdatedAt',
          'age'
        ]);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /skills/{skillId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /insights/{insightId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /market_trends/{trendId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    // Own admins/{uid} readable to verify promotion before ID token refresh; full list only for admins.
    match /admins/{adminUid} {
      allow read: if isSignedIn() && (
        request.auth.uid == adminUid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }
  }
}
